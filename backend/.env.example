# Copy to .env and adjust as needed. All vars are prefixed TRANSCRIBE_.

TRANSCRIBE_HOST=0.0.0.0
TRANSCRIBE_PORT=8000
TRANSCRIBE_LOG_LEVEL=info

# faster-whisper
TRANSCRIBE_WHISPER_MODEL_SIZE=small
# Use "cpu" for local dev on machines without an NVIDIA GPU, "cuda" on the deploy target.
TRANSCRIBE_WHISPER_DEVICE=cpu
# Use "int8" on cpu, "float16" on cuda.
TRANSCRIBE_WHISPER_COMPUTE_TYPE=int8
TRANSCRIBE_WHISPER_BEAM_SIZE=1
TRANSCRIBE_TRANSCRIBE_EXECUTOR_WORKERS=1

# Audio / VAD
TRANSCRIBE_SAMPLE_RATE=16000
TRANSCRIBE_VAD_AGGRESSIVENESS=2
TRANSCRIBE_VAD_FRAME_MS=30
TRANSCRIBE_VAD_START_FRAMES=3
TRANSCRIBE_VAD_SILENCE_MS=600
TRANSCRIBE_MAX_SEGMENT_MS=9000
TRANSCRIBE_MIN_SEGMENT_MS=250

# Translation
# "argos" (free, offline, no key -- default) | "google" (needs a billed API key) | "passthrough"
TRANSCRIBE_TRANSLATION_PROVIDER=argos
# Only used if TRANSCRIBE_TRANSLATION_PROVIDER=google. Falls back to passthrough with a warning if unset.
TRANSCRIBE_GOOGLE_TRANSLATE_API_KEY=
TRANSCRIBE_TRANSLATION_TIMEOUT_S=5.0
TRANSCRIBE_MIN_LANGUAGE_CONFIDENCE=0.6

# Queueing / relay
TRANSCRIBE_FRAME_QUEUE_MAXSIZE=200
TRANSCRIBE_RELAY_TO_SELF=false
