# Transcription backend WebSocket URL.
# Dev: ws://localhost:8000  |  Prod: wss://<your-hf-space>.hf.space
VITE_TRANSCRIBE_WS_URL=ws://localhost:8000

# Optional dedicated TURN relay for reliable CROSS-NETWORK calls.
# Leave unset to fall back to the shared (rate-limited) public relay.
# Get free dedicated credentials (50GB/mo) at metered.ca -- see DEPLOY.md.
# VITE_TURN_URL may be a comma-separated list of turn:/turns: URLs.
# VITE_TURN_URL=turn:xxx.relay.metered.ca:80,turn:xxx.relay.metered.ca:443,turn:xxx.relay.metered.ca:443?transport=tcp
# VITE_TURN_USERNAME=your-metered-username
# VITE_TURN_CREDENTIAL=your-metered-credential
